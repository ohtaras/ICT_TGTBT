# Railway sets DATABASE_URL automatically when you add a PostgreSQL service
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: protect your API with a key (set the same value in VITE_API_KEY)
API_KEY=your-secret-key

# Optional: if API_KEY is set, the frontend must send this header
VITE_API_KEY=your-secret-key

# Railway sets PORT automatically
PORT=3000
